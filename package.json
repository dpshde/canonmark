{
  "name": "versemark",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "mobile": "npm run start -w @versemark/mobile",
    "mobile:start": "npm run start -w @versemark/mobile",
    "web": "npm run dev -w @versemark/web",
    "web:build": "npm run build -w @versemark/web",
    "dev": "npm run web",
    "build": "npm run build -w @versemark/web",
    "test": "npm run test -w @versemark/core && npm run test -w @versemark/web",
    "test:core": "npm run test -w @versemark/core",
    "typecheck": "npm run typecheck -w @versemark/core && npm run typecheck -w @versemark/web && npm run typecheck -w @versemark/mobile",
    "typecheck:core": "npm run typecheck -w @versemark/core",
    "build:data": "npm run build:data -w @versemark/web",
    "export:mobile": "npm run export -w @versemark/mobile"
  },
  "engines": {
    "node": ">=20"
  }
}
